        "selector": "JSXOpeningElement[name.name='MobileChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|children|className|key|ref|className|style|children)$/]",
        "message": "<MobileChip> doesn't accept that prop. Declared props: tone, icon, children, className."
