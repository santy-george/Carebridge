{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/icons/**",
              "components/buttons/**",
              "components/cards/**",
              "components/chips/**",
              "components/data/**",
              "components/forms/**",
              "components/icons/**",
              "components/mobile/**",
              "components/navigation/**",
              "components/wellness/**",
              "ui_kits/admin-portal/**",
              "ui_kits/field-app/**",
              "ui_kits/wellness-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Urbanist))/i]",
        "message": "Font not provided by the design system. Available: Urbanist."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:initials|size|src|style|className|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: initials, size, src, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Avatar> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|title|children|className|key|ref|className|style|children)$/]",
        "message": "<Banner> doesn't accept that prop. Declared props: tone, icon, title, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:ok|warn|alert|info)$/]",
        "message": "<Banner> tone must be one of 'ok' | 'warn' | 'alert' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomNavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|href|sos|key|ref|className|style|children)$/]",
        "message": "<BottomNavItem> doesn't accept that prop. Declared props: id, label, icon, href, sos."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|block|disabled|children|className|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, block, disabled, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|outline|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'outline' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Button> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|link|children|className|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, subtitle, link, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='CheckinChoice'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|selected|tone|key|ref|className|style|children)$/]",
        "message": "<CheckinChoice> doesn't accept that prop. Declared props: label, selected, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='CheckinChoice'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:warn|alert)$/]",
        "message": "<CheckinChoice> tone must be one of 'warn' | 'alert'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|error|inputProps|className|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, error, inputProps, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeroCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:tag|children|onClick|className|key|ref|className|style|children)$/]",
        "message": "<HeroCard> doesn't accept that prop. Declared props: tag, children, onClick, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|fill|className|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, fill, className."
      },
