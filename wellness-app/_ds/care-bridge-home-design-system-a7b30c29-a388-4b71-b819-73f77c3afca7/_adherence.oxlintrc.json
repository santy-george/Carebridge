        "message": "<KpiCard> doesn't accept that prop. Declared props: label, value, icon, footnote, delta, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|tone|title|subtitle|value|unit|chevron|onClick|key|ref|className|style|children)$/]",
        "message": "<ListRow> doesn't accept that prop. Declared props: icon, tone, title, subtitle, value, unit, chevron, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|ok|warn|alert)$/]",
        "message": "<ListRow> tone must be one of 'accent' | 'ok' | 'warn' | 'alert'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MedicationItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|name|dose|time|state|key|ref|className|style|children)$/]",
        "message": "<MedicationItem> doesn't accept that prop. Declared props: icon, name, dose, time, state."
