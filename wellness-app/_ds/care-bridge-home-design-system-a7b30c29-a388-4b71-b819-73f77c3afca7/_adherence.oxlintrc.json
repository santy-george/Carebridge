        "selector": "JSXOpeningElement[name.name='MobileButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|block|disabled|children|className|key|ref|className|style|children)$/]",
        "message": "<MobileButton> doesn't accept that prop. Declared props: variant, size, icon, block, disabled, children, className."
