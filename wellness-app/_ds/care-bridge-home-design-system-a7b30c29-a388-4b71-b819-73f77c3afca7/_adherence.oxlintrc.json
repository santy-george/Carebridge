        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Icon> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='InfoCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|title|children|className|key|ref|className|style|children)$/]",
        "message": "<InfoCard> doesn't accept that prop. Declared props: tone, icon, title, children, className."
